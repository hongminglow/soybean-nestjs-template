# This file is automatically read by Docker Compose to configure its global behavior!
# Setting this to 1 forces Docker to safely build containers one-by-one sequentially.
# It protects your tiny AWS EC2 server from crashing due to running out of memory!
# 
# When you deploy in your office with a high-end PC, just comment out the line below 
# (by putting a # in front of it) to re-enable blazing-fast parallel background builds.

COMPOSE_PARALLEL_LIMIT=1
